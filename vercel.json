{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/invoices", "destination": "https://themis-orchestrator.fly.dev/invoices" },
    { "source": "/packets/:id/pdf", "destination": "https://themis-orchestrator.fly.dev/packets/:id/pdf" },
    { "source": "/packets/:id/json", "destination": "https://themis-orchestrator.fly.dev/packets/:id/json" },
    { "source": "/compliance-report/:id", "destination": "https://themis-orchestrator.fly.dev/compliance-report/:id" },
    { "source": "/events", "destination": "https://themis-orchestrator.fly.dev/events" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
