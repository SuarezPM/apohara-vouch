# ─── Build artifacts ───────────────────────────────────────────────
/target
**/target
**/*.rs.bk
Cargo.lock.bak
# External rustc side-output (e.g. rustc --emit=metadata librust_out.rmeta)
*.rmeta
# Vercel build output (rebuilt by scripts/vercel-build.sh on every deploy)
/public
# Python bytecode (C-12 cross-framework peers)
/__pycache__/
**/__pycache__/
*.pyc
*.pyo

# ─── Local state & archives (not for public consumption) ───────────
# Pre-VOUCH development archive — kept locally for reference, never published
/.archive/
# OMC workflow state (operator-only — never judge-visible)
/.omc/
crates/*/.omc/  # noqa: ERA001  # OMC state inside crate subdirs
# Python virtualenvs (per-crate)
/.venv/
crates/*/.venv/  # noqa: ERA001
# Playwright MCP + Playwright caches
/.playwright-mcp/
/playwright-report/
/playwright/.cache/
# Node deps (Playwright etc.)
/node_modules/
# Session / IDE caches
/.claude/settings.local.json
/.claude/sessions/
/.mcp.json.local
# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
*~
# ─── Operator-only AI agent workflow (judges don't need this) ────
# The AGENTS.md is the renamed internal workflow guide (was CLAUDE.md).
# Public equivalent lives in README.md + CONTRIBUTING.md.
# Keeping it local: avoids leaking the AI-assisted dev workflow.
/AGENTS.md

# ─── Secrets (NEVER commit) ────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
/keys/
/demo-tenant-keys/
# Rendered Band agent config (contains real api_keys) — template is committed
crates/themis-band-client/agent-config/agent_config.yaml
/crates/**/agent_config.yaml

# ─── Demo evidence (built locally, regenerated for each demo run) ──
/demo/expected-evidence/*.rekor
/demo/expected-evidence/*.sig
/demo/temp/

