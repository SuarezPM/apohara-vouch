# ─── Build artifacts ───────────────────────────────────────────────
/target
**/target
**/*.rs.bk
Cargo.lock.bak
# External rustc side-output (e.g. rustc --emit=metadata librust_out.rmeta)
*.rmeta
# Vercel build output (rebuilt by scripts/vercel-build.sh on every deploy)
/public
# Python bytecode (C-12 cross-framework peers)
/__pycache__/
**/__pycache__/
*.pyc
*.pyo

# ─── Local state & archives (not for public consumption) ───────────
# Pre-THEMIS development archive — kept locally for reference, never published
/.archive/
# OMC workflow state
/.omc/
crates/*/.omc/  # noqa: ERA001  # OMC state inside crate subdirs
# Python virtualenvs (per-crate)
/.venv/
crates/*/.venv/  # noqa: ERA001
# Session / IDE caches
/.claude/settings.local.json
/.claude/sessions/
/.mcp.json.local

# ─── Secrets (NEVER commit) ────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
/keys/
/demo-tenant-keys/
# Rendered Band agent config (contains real api_keys) — template is committed
crates/themis-band-client/agent-config/agent_config.yaml
/crates/**/agent_config.yaml

# ─── Demo evidence (built locally, regenerated for each demo run) ──
/demo/expected-evidence/*.rekor
/demo/expected-evidence/*.sig
/demo/temp/

# ─── IDE ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.helix/

# ─── OS ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Coverage / test artifacts ─────────────────────────────────────
/coverage
/coverage.*
*.lcov
*.snap.new
/test-output/
/playwright-report/
/playwright/.cache/
/test-results/

# ─── Local cache ───────────────────────────────────────────────────
.cache/
.turbo/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.vercel
# Node deps (Playwright etc.)
/node_modules/

# OMC state leakage guard
crates/themis-evidence/proto/rekor/v2/.omc/
# All OMC state dirs at any depth
**/.omc
**/.omc/**
